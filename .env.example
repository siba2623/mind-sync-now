# MindSync Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google AI (Optional - for AI features)
VITE_GOOGLE_AI_API_KEY=your-google-ai-key

# Spotify Integration (Optional - for music therapy)
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Note: Never commit the actual .env file to Git!
# These variables must start with VITE_ to be accessible in the app
